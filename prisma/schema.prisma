generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Settings {
  id             String   @id @default("singleton")
  businessName   String
  tagline        String   @default("Sales & Inventory")
  currencySymbol String   @default("₦")
  accentColor    String   @default("indigo")
  setupComplete  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id        String  @id @default(cuid())
  name      String
  username  String  @unique
  password  String
  role      String  @default("rep")
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  sales           Sale[]
  purchases       Purchase[]
  expenses        Expense[]
  stockAdjustments StockAdjustment[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique // SKU prefix, e.g. ORA for Oraimo
  createdAt DateTime @default(now())
}

// A product that needs the owner's attention before it joins the catalogue —
// e.g. an Excel-import row with an unknown category/brand, or a product a rep
// sold that wasn't in the catalogue yet. The owner reviews each one, maps it to
// an existing (or new) category/brand, then approves it into a ProductVariant.
model PendingProduct {
  id             String   @id @default(cuid())
  name           String
  brandInput     String?  // raw brand text the owner/rep typed
  categoryInput  String?  // raw category text the owner/rep typed
  sku            String?
  unitCost       Int      @default(0)
  startingPrice  Int      @default(0)
  suggestedPrice Int      @default(0)
  openingStock   Int      @default(0)
  reorderLevel   Int      @default(5)
  barcode        String?
  source         String   @default("import") // import | manual | staff-sale
  reason         String?
  qtySold        Int?     // context for staff-sale
  reportedBy     String?  // user id of the rep, for staff-sale
  reportedByName String?
  createdAt      DateTime @default(now())
}

model ProductGroup {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?

  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id             String  @id @default(cuid())
  sku            String  @unique
  name           String
  category       String
  brand          String
  unitCost       Int
  startingPrice  Int     @default(0)
  suggestedPrice Int     @default(0)
  openingStock   Int     @default(0)
  currentStock   Int     @default(0)
  reorderLevel   Int     @default(5)
  barcode        String?
  isActive       Boolean @default(true)

  productGroupId String
  productGroup   ProductGroup @relation(fields: [productGroupId], references: [id])

  sales           Sale[]
  purchases       Purchase[]
  stockAdjustments StockAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id             String   @id @default(cuid())
  timestamp      DateTime @default(now())
  date           DateTime
  time           String
  receiptRef     String
  qty            Int
  enteredPrice   Int     @default(0)
  startingPrice  Int     @default(0)
  suggestedPrice Int     @default(0)
  discount       Int      @default(0)
  totalAmount    Int
  unitCost       Int
  grossProfit    Int
  paymentMethod  String
  channel        String   @default("In-store")
  customer       String?
  note           String?

  // Off-catalogue ("custom") sales have no variant; the product name is kept here.
  customProductName String?

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Purchase {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  date          DateTime
  time          String
  purchaseRef   String
  supplier      String
  qty           Int
  unitCost      Int
  totalCost     Int
  paymentMethod String
  note          String?

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  date        DateTime
  time        String
  expenseRef  String
  category    String
  description String?
  amount      Int
  paymentMethod String
  note        String?

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model StockAdjustment {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  date      DateTime
  time      String
  reason    String
  qty       Int
  note      String?

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
